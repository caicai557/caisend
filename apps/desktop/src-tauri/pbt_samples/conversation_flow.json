{
    "name": "Simple Conversation Flow",
    "description": "A simple behavior tree that responds to keywords in messages",
    "root_node_id": "root",
    "nodes": {
        "root": {
            "id": "root",
            "node_type": "Selector",
            "config": {
                "children": [
                    "help_branch",
                    "invite_branch",
                    "default_reply"
                ]
            }
        },
        "help_branch": {
            "id": "help_branch",
            "node_type": "Sequence",
            "config": {
                "children": [
                    "check_help",
                    "send_help"
                ]
            }
        },
        "check_help": {
            "id": "check_help",
            "node_type": "Condition",
            "config": {
                "condition_type": "HasKeyword",
                "keyword": "help"
            }
        },
        "send_help": {
            "id": "send_help",
            "node_type": "Action",
            "config": {
                "action_type": "send_message",
                "peer_id": "{{context.peer_id}}",
                "content": "你好！我是自动客服。有什么可以帮助你的吗？"
            }
        },
        "invite_branch": {
            "id": "invite_branch",
            "node_type": "Sequence",
            "config": {
                "children": [
                    "check_invite",
                    "save_invite"
                ]
            }
        },
        "check_invite": {
            "id": "check_invite",
            "node_type": "Condition",
            "config": {
                "condition_type": "HasKeyword",
                "keyword": "invite"
            }
        },
        "save_invite": {
            "id": "save_invite",
            "node_type": "Action",
            "config": {
                "action_type": "send_message",
                "peer_id": "{{context.peer_id}}",
                "content": "已收到邀请链接，感谢分享！"
            }
        },
        "default_reply": {
            "id": "default_reply",
            "node_type": "Action",
            "config": {
                "action_type": "send_message",
                "peer_id": "{{context.peer_id}}",
                "content": "收到你的消息了，稍后回复。"
            }
        }
    }
}