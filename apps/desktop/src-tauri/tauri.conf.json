{
    "productName": "teleflow-2025",
    "version": "0.0.0",
    "identifier": "com.teleflow.app",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm build",
        "devUrl": "http://localhost:1420",
        "frontendDist": "../dist"
    },
    "bundle": {
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "targets": [
            "msi",
            "nsis"
        ],
        "windows": {
            "wix": {
                "language": "en-US"
            },
            "nsis": {
                "displayLanguageSelector": false
            }
        }
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Teleflow 2025",
                "width": 800,
                "height": 600,
                "resizable": true,
                "fullscreen": false,
                "additionalBrowserArgs": "--remote-debugging-port=9222"
            },
            {
                "label": "hud_overlay",
                "title": "Ghost Cockpit",
                "url": "/cockpit",
                "width": 350,
                "height": 600,
                "transparent": true,
                "decorations": false,
                "alwaysOnTop": true,
                "resizable": false,
                "skipTaskbar": true,
                "visible": false,
                "x": 0,
                "y": 100
            }
        ],
        "security": {
            "csp": null,
            "capabilities": [
                {
                    "identifier": "main-capability",
                    "windows": [
                        "main"
                    ],
                    "permissions": [
                        "core:event:allow-listen",
                        "core:event:allow-emit",
                        "core:event:allow-unlisten"
                    ]
                }
            ]
        }
    }
}