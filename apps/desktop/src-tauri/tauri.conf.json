{
    "productName": "teleflow-2025",
    "version": "0.0.0",
    "identifier": "com.teleflow.app",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm build",
        "devUrl": "http://localhost:1420",
        "frontendDist": "../dist"
    },
    "bundle": {
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "targets": [
            "msi",
            "nsis"
        ],
        "windows": {
            "wix": {
                "language": "en-US"
            },
            "nsis": {
                "displayLanguageSelector": false
            }
        }
    },
    "app": {
        "windows": [
            {
                "title": "Teleflow 2025",
                "width": 800,
                "height": 600,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        }
    }
}
